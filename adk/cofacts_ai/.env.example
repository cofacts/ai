# Gemini via Vertex AI. The agent reads article media as native gs:// URIs, which
# Vertex supports directly. Auth uses Application Default Credentials (ADC):
# on Cloud Run the runtime service account is used automatically; for local dev run
# `gcloud auth application-default login` or set GOOGLE_APPLICATION_CREDENTIALS to a
# service-account key file. That identity needs Vertex AI access (roles/aiplatform.user)
# and read access to the media bucket (roles/storage.objectViewer on cofacts-media-collection).
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
# Local dev only — path to a service-account key JSON (omit on Cloud Run):
# GOOGLE_APPLICATION_CREDENTIALS=

# rumors-api base URL
COFACTS_API_URL=https://dev-api.cofacts.tw

# Langfuse credentials (https://langfuse.cofacts.tw → Project Settings)
# Optional: skip to disable Langfuse instrumentation
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://langfuse.cofacts.tw

# PostgreSQL session storage (optional, falls back to SQLite for local dev)
DATABASE_URL=
