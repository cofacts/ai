# Google Gemini API key (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=

# Service-account JSON used to register Cofacts media (GCS objects) with the
# Gemini Files API so the model can read video/image/audio attachments.
# - Local / docker-compose (outside GCP): point this at a mounted SA key file
#   whose service account has roles/storage.objectViewer on the media bucket.
# - Cloud Run: leave empty; the runtime service account is used via ADC.
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/sa.json

# rumors-api base URL
COFACTS_API_URL=https://dev-api.cofacts.tw

# Langfuse credentials (https://langfuse.cofacts.tw → Project Settings)
# Optional: skip to disable Langfuse instrumentation
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://langfuse.cofacts.tw

# PostgreSQL session storage (optional, falls back to SQLite for local dev)
DATABASE_URL=
