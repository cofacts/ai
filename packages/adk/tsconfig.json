{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "moduleResolution": "node",
    "outDir": "dist",
    "baseUrl": ".",
    "types": ["node"],
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@cofacts-ai/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*"]
}
